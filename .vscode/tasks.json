{
    "version": "2.0.0",
    "tasks": [
        {
  "label": "build",
  "type": "shell",
  "command": "/usr/bin/g++",
  "args": [
    "-std=c++20",
    "-O3",
    "-march=native",
    "-Wall",
    "-Wextra",
    "${file}",
    "-o",
    "${fileDirname}/${fileBasenameNoExtension}"
  ],
  "group": {
    "kind": "build",
    "isDefault": true
  },
  "problemMatcher": ["$gcc"]
}
    ]
}